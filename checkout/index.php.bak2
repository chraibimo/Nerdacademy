          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h4V10H2z"/><path d="M10 20h4V4h-4z"/><path d="M18 20h4v-8h-4z"/></svg>
          <?= $courseLevel ?>
        </span>
        <?php endif; ?>
        <?php if ($courseDuration): ?>
