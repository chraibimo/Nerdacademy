          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <?= $courseDuration ?>
        </span>
        <?php endif; ?>
        <?php if ($courseLessons > 0): ?>
        <span class="mpill">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          <?= $courseLessons ?> lessons
        </span>
        <?php endif; ?>
        <?php if ($courseStudents > 0): ?>
        <span class="mpill">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <?= number_format($courseStudents) ?> students
        </span>
        <?php endif; ?>
      </div>

      <?php if ($courseInstructor): ?>
      <div class="instructor-row">
        <div class="inst-av"><?= strtoupper(mb_substr($courseInstructor, 0, 1)) ?></div>
        <div>
          <div class="inst-name"><?= $courseInstructor ?></div>
          <?php if ($courseInstructorTitle): ?>
            <div class="inst-title"><?= $courseInstructorTitle ?></div>
          <?php endif; ?>
        </div>
      </div>
      <?php endif; ?>

      <?php if ($courseRating > 0): ?>
      <div class="rating-row">
        <span class="stars">&#9733;</span>
        <span class="rating-val"><?= number_format($courseRating, 1) ?></span>
        <?php if ($courseReviews > 0): ?>
          <span class="rating-cnt">(<?= number_format($courseReviews) ?> reviews)</span>
        <?php endif; ?>
      </div>
      <?php endif; ?>

      <?php if (!empty($courseOutcomes)): ?>
      <div class="outcomes-box">
        <h3>What you&rsquo;ll learn</h3>
        <ul class="outcomes-list">
          <?php foreach (array_slice($courseOutcomes, 0, 6) as $outcome): ?>
          <li>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
            <?= htmlspecialchars((string)$outcome, ENT_QUOTES|ENT_HTML5, 'UTF-8') ?>
          </li>
          <?php endforeach; ?>
        </ul>
      </div>
      <?php endif; ?>

      <div class="price-card">
        <?php if ($discountPercent > 0): ?>
        <div class="price-line">
          <span>Original price</span>
          <span class="strike">$<?= $originalDisplay ?></span>
        </div>
        <div class="price-line">
          <span>Discount (<?= (int)$discountPercent ?>% off)</span>
          <span class="disc-badge">&minus;$<?= $savingsDisplay ?></span>
        </div>
        <?php endif; ?>
        <div class="price-line total">
          <span>Total due today</span>
          <span class="amount">$<?= $finalDisplay ?></span>
        </div>
      </div>

      <div class="trust-strip">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        30-day money-back guarantee &nbsp;&middot;&nbsp; Lifetime access
      </div>

    </div><!-- /s-inner -->
  </aside>

  <!-- ── RIGHT: Payment ────────────────────────────────────────── -->
  <main class="col-payment">
    <div class="p-inner">

      <div class="p-head">
        <div class="p-head-icon">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <div>
          <h1>Complete your order</h1>
          <p>256-bit SSL &amp; secured by Stripe</p>
        </div>
      </div>

      <div class="amount-chip">
        <div class="ac-left">
          <div class="ac-label">Enrolling in</div>
          <div class="ac-title"><?= $courseTitle ?></div>
        </div>
        <div class="ac-amount">$<?= $finalDisplay ?></div>
      </div>

      <iframe
        src="<?= htmlspecialchars($iframeSrc, ENT_QUOTES|ENT_HTML5, 'UTF-8') ?>"
        class="pay-frame"
        id="payment-iframe"
        allow="payment"
        loading="eager"
        title="Payment form"
      ></iframe>

      <div class="pay-footer">
        <div class="pay-footer-row">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Powered by Stripe &nbsp;&middot;&nbsp; Your payment info is always encrypted
        </div>
        <div class="pay-methods">
          <span class="pm-badge">VISA</span>
          <span class="pm-badge">MC</span>
          <span class="pm-badge">AMEX</span>
          <span class="pm-badge">Apple Pay</span>
          <span class="pm-badge">G Pay</span>
        </div>
      </div>

    </div><!-- /p-inner -->
  </main>

</div><!-- /checkout-shell -->

<script>
(function () {
  'use strict';
  var BASE_URL = <?= $jsBaseUrl ?>;
  var overlay  = document.getElementById('xoverlay');

  function showOverlay() {
    overlay.classList.add('active');
    overlay.removeAttribute('aria-hidden');
  }
  function hideOverlay() {
    overlay.classList.remove('active');
    overlay.setAttribute('aria-hidden', 'true');
  }

  window.addEventListener('message', function (e) {
    if (!e.data || typeof e.data !== 'object') return;
    switch (e.data.type) {
      case 'express_pay_open':
        showOverlay();
        break;
      case 'express_pay_close':
        hideOverlay();
        break;
      case 'checkout_complete':
        hideOverlay();
        window.location.href = e.data.redirect_url || (BASE_URL + '/my-courses');
        break;
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') hideOverlay();
  });
})();
</script>
</body>
</html>
