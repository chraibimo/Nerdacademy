</div>

<div class="checkout-shell">

  <!-- ── LEFT: Dark order summary ──────────────────────────────── -->
  <aside class="col-summary">

    <div class="aurora" aria-hidden="true">
      <div class="orb orb-a"></div>
      <div class="orb orb-b"></div>
      <div class="orb orb-c"></div>
